{
  "name": "subtitletoolkit",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "verify:seo:ready": "pnpm build && pnpm audit:serp && pnpm audit:content-meta && pnpm test:ads:ready && pnpm test:gsc:analyze && pnpm test:gsc:day0:list && pnpm test:gsc:day0:record && pnpm test:gsc:review:ready && pnpm test:growth:status && pnpm test:promotion:kit && pnpm test:promotion:record && pnpm verify:seo:dist && pnpm verify:gsc:day0",
    "audit:serp": "node scripts/audit-serp-meta.mjs",
    "audit:content-meta": "node scripts/audit-content-meta.mjs",
    "test:ads:ready": "node scripts/test-ad-readiness.mjs",
    "test:gsc:analyze": "node scripts/test-gsc-analyzer.mjs",
    "test:gsc:day0:record": "node scripts/test-gsc-day0-record.mjs",
    "test:gsc:day0:list": "node scripts/test-gsc-day0-list.mjs",
    "test:gsc:review:ready": "node scripts/test-gsc-weekly-review.mjs",
    "test:growth:status": "node scripts/test-growth-status.mjs",
    "test:promotion:kit": "node scripts/test-promotion-submission.mjs",
    "test:promotion:record": "node scripts/test-promotion-record.mjs",
    "verify:gsc:submit-ready": "pnpm verify:seo:live && pnpm verify:gsc:day0:live",
    "ads:ready": "node scripts/verify-ad-readiness.mjs",
    "verify:gsc:day0": "node scripts/verify-gsc-day0.mjs",
    "verify:gsc:day0:live": "node scripts/verify-gsc-day0.mjs --live",
    "growth:status": "node scripts/show-growth-status.mjs",
    "gsc:day0:record": "node scripts/record-gsc-day0-submission.mjs",
    "gsc:day0:list": "node scripts/prepare-gsc-day0-submission.mjs",
    "gsc:review:ready": "node scripts/prepare-gsc-weekly-review.mjs",
    "promotion:kit": "node scripts/prepare-promotion-submission.mjs",
    "promotion:record": "node scripts/record-promotion-action.mjs",
    "verify:seo:dist": "SEO_VERIFY_DIST=1 node scripts/verify-production-seo.mjs",
    "verify:seo:live": "SEO_VERIFY_RETRIES=10 SEO_VERIFY_RETRY_DELAY_MS=30000 pnpm verify:seo",
    "verify:seo": "node scripts/verify-production-seo.mjs",
    "gsc:analyze": "node scripts/analyze-gsc-export.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "astro": "^6.1.8",
    "sharp": "^0.34.3"
  }
}
