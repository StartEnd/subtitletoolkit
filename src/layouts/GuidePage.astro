---
import SiteLayout from './SiteLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import type { CollectionEntry } from 'astro:content';
import { SITE_TITLE } from '../consts';
import { guideCategoryMeta } from '../lib/guides/catalog';
import type { SubtitleTool } from '../lib/subtitles/catalog';

type GuideEntry = CollectionEntry<'guides'>;

type Props = GuideEntry['data'] & {
	relatedGuides?: GuideEntry[];
	primaryToolData?: SubtitleTool | null;
	relatedToolData?: SubtitleTool[];
};

const {
	title,
	seoTitle,
	seoDescription,
	description,
	pubDate,
	updatedDate,
	category,
	tags = [],
	faqs = [],
	relatedGuides = [],
	primaryToolData = null,
	relatedToolData = [],
} = Astro.props as Props;

const pageTitle = seoTitle ?? `${title} | ${SITE_TITLE}`;
const pageDescription = seoDescription ?? description;

const categoryMeta = guideCategoryMeta[category];

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Guides', href: '/guides/' },
	{ label: categoryMeta.label, href: categoryMeta.hubPath },
	{ label: title },
];

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Article Schema
const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	"headline": title,
	"description": pageDescription,
	...(tags.length > 0
		? {
			"keywords": tags.join(', '),
			"about": tags.map((tag) => ({
				"@type": "Thing",
				"name": tag,
			})),
		}
		: {}),
	"datePublished": pubDate.toISOString(),
	"dateModified": (updatedDate || pubDate).toISOString(),
	"author": {
		"@type": "Organization",
		"name": "SubtitleToolkit",
		"url": Astro.site
	},
	"publisher": {
		"@type": "Organization",
		"name": "SubtitleToolkit",
		"url": Astro.site,
		"logo": {
			"@type": "ImageObject",
			"url": new URL('/og-preview.png', Astro.site).toString()
		}
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": canonicalURL.toString()
	}
};

const faqSchema = faqs.length > 0
	? {
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"mainEntity": faqs.map((faq) => ({
			"@type": "Question",
			"name": faq.question,
			"acceptedAnswer": {
				"@type": "Answer",
				"text": faq.answer,
			},
		})),
	}
	: null;
---

<SiteLayout
	title={pageTitle}
	description={pageDescription}
	pageType="article"
	publishedTime={pubDate}
	modifiedTime={updatedDate}
>
	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
	{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />}
	<article class="guide-article">
		<Breadcrumbs items={breadcrumbItems} />
		<!-- Article Header -->
		<header class="guide-header">
			<div class="guide-kicker">
				<span class="eyebrow">Subtitle guide</span>
				<span class="guide-category">{categoryMeta.label}</span>
			</div>
			<h1>{title}</h1>
			<div class="guide-meta">
				<FormattedDate date={pubDate} />
				{
					updatedDate && (
						<span class="guide-updated">Updated <FormattedDate date={updatedDate} /></span>
					)
				}
			</div>
			<hr />
		</header>

		<!-- TL;DR -->
		<div class="tldr">
			<p><strong>TL;DR</strong> — {description}</p>
		</div>

		<div class="guide-tool-strip">
			<div>
				<p class="guide-tool-strip-label">Related tool</p>
				<p class="guide-tool-strip-title">
					{primaryToolData ? primaryToolData.title : 'Free subtitle tools'}
				</p>
			</div>
			<a
				class="button secondary"
				href={primaryToolData ? `/tools/${primaryToolData.id}/` : '/tools/'}
				data-guide-tool-cta
				data-guide-tool-placement="top"
				data-guide-tool-id={primaryToolData?.id ?? 'all-tools'}
			>
				{primaryToolData ? `Open ${primaryToolData.shortTitle}` : 'Browse tools'} <span aria-hidden="true">&rarr;</span>
			</a>
		</div>

		<!-- Content -->
		<div class="prose">
			<slot />
		</div>

		<!-- Related Tool CTA -->
		<div class="guide-cta">
			<p class="guide-cta-title">
				{primaryToolData ? `Use the ${primaryToolData.title}` : 'Try it with our free tools'}
			</p>
			<p class="guide-cta-text">
				{
					primaryToolData
						? `${primaryToolData.description} No signup, no upload, and everything runs locally in the browser.`
						: 'Convert, shift, and clean subtitle files directly in your browser. No signup, no upload.'
				}
			</p>
			<a
				class="button"
				href={primaryToolData ? `/tools/${primaryToolData.id}/` : '/tools/'}
				data-guide-tool-cta
				data-guide-tool-placement="bottom"
				data-guide-tool-id={primaryToolData?.id ?? 'all-tools'}
			>
				{primaryToolData ? `Open ${primaryToolData.shortTitle}` : 'Browse tools'} <span aria-hidden="true">&rarr;</span>
			</a>
		</div>

		{
			relatedToolData.length > 0 && (
				<section class="guide-related-tools" aria-labelledby="guide-related-tools-title">
					<p class="guide-related-tools-kicker">More tools for this workflow</p>
					<h2 id="guide-related-tools-title">Continue with a related subtitle tool</h2>
					<div class="guide-related-tools-grid">
						{relatedToolData.map((tool) => (
							<a
								class="guide-related-tool-card"
								href={`/tools/${tool.id}/`}
								data-guide-tool-cta
								data-guide-tool-placement="related-tools"
								data-guide-tool-id={tool.id}
							>
								<span>{tool.shortTitle}</span>
								<strong>{tool.title}</strong>
								<em>{tool.description}</em>
							</a>
						))}
					</div>
				</section>
			)
		}

		{
			relatedGuides.length > 0 && (
				<section class="related-guides" aria-labelledby="related-guides-title">
					<div class="related-guides-head">
						<div>
							<p class="related-guides-kicker">{categoryMeta.label}</p>
							<h2 id="related-guides-title">Read next</h2>
						</div>
						<a class="related-guides-link" href="/guides/">View all guides</a>
					</div>
					<div class="related-guides-grid">
						{relatedGuides.map((guide) => (
							<article class="related-guide-card">
								<p class="related-guide-meta">{guideCategoryMeta[guide.data.category].label}</p>
								<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
								<p>{guide.data.description}</p>
							</article>
						))}
					</div>
				</section>
			)
		}
	</article>
	<script>
		document.querySelectorAll('[data-guide-tool-cta]').forEach((link) => {
			link.addEventListener('click', () => {
				if (typeof window !== 'undefined' && typeof window.plausible === 'function') {
					window.plausible('guide_tool_cta_click', {
						props: {
							tool: link.getAttribute('data-guide-tool-id') || 'all-tools',
							placement: link.getAttribute('data-guide-tool-placement') || 'unknown',
						},
					});
				}
			});
		});
	</script>
</SiteLayout>

<style>
	.guide-article {
		max-width: var(--max-width-narrow);
		margin: 0 auto;
	}

	.guide-header {
		margin-bottom: var(--space-8);
	}

	.guide-kicker {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-3);
	}

	.guide-category {
		display: inline-flex;
		align-items: center;
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.guide-header h1 {
		margin-bottom: var(--space-3);
	}

	.guide-meta {
		display: flex;
		align-items: center;
		gap: var(--space-4);
		color: var(--color-secondary);
		font-size: 0.875rem;
		margin-bottom: var(--space-4);
	}

	.guide-updated {
		color: var(--color-tertiary);
		font-style: italic;
	}

	.guide-meta hr {
		margin-top: var(--space-4);
	}

	.guide-tool-strip {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		padding: var(--space-4) var(--space-5);
		border: 1px solid var(--color-subtle);
		border-radius: var(--radius-md);
		background: var(--color-surface);
		box-shadow: var(--shadow-sm);
		margin: calc(-1 * var(--space-2)) 0 var(--space-8);
	}

	.guide-tool-strip-label {
		margin: 0 0 var(--space-1);
		color: var(--color-tertiary);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.guide-tool-strip-title {
		margin: 0;
		color: var(--color-base);
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.35;
	}

	/* Related tool CTA */
	.guide-cta {
		margin-top: var(--space-16);
		padding: var(--space-8);
		background: var(--color-accent);
		border-radius: var(--radius-lg);
		text-align: center;
	}

	.guide-cta-title {
		color: white;
		font-size: 1.25rem;
		font-weight: 700;
		margin-bottom: var(--space-2);
	}

	.guide-cta-text {
		color: rgba(255, 255, 255, 0.8);
		font-size: 0.9375rem;
		margin-bottom: var(--space-6);
	}

	.guide-cta .button {
		background: white;
		color: var(--color-accent);
	}

	.guide-cta .button:hover {
		background: var(--color-accent-light);
		color: var(--color-accent-hover);
		transform: translateY(-1px);
		box-shadow: var(--shadow-md);
	}

	.guide-related-tools {
		margin-top: var(--space-16);
	}

	.guide-related-tools-kicker {
		margin: 0 0 var(--space-2);
		color: var(--color-tertiary);
		font-size: 0.8125rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.guide-related-tools h2 {
		margin-bottom: var(--space-5);
	}

	.guide-related-tools-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-4);
	}

	.guide-related-tool-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding: var(--space-5);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-surface);
		color: var(--color-primary);
		text-decoration: none;
	}

	.guide-related-tool-card:hover {
		border-color: var(--color-accent);
	}

	.guide-related-tool-card span {
		color: var(--color-accent);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.guide-related-tool-card strong {
		font-size: 1rem;
	}

	.guide-related-tool-card em {
		color: var(--color-secondary);
		font-size: 0.875rem;
		font-style: normal;
		line-height: 1.5;
	}

	.related-guides {
		margin-top: var(--space-16);
		padding-top: var(--space-10);
		border-top: 1px solid var(--color-border);
	}

	.related-guides-head {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: var(--space-4);
		margin-bottom: var(--space-6);
	}

	.related-guides-kicker {
		margin: 0 0 var(--space-2);
		color: var(--color-tertiary);
		font-size: 0.8125rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.related-guides-head h2 {
		margin: 0;
	}

	.related-guides-link {
		color: var(--color-accent);
		font-weight: 600;
		text-decoration: none;
	}

	.related-guides-link:hover {
		color: var(--color-accent-hover);
		text-decoration: underline;
	}

	.related-guides-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-4);
	}

	.related-guide-card {
		padding: var(--space-5);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-background);
	}

	.related-guide-meta {
		margin: 0 0 var(--space-2);
		color: var(--color-tertiary);
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.related-guide-card h3 {
		margin-bottom: var(--space-2);
		font-size: 1rem;
	}

	.related-guide-card h3 a {
		color: var(--color-primary);
		text-decoration: none;
	}

	.related-guide-card h3 a:hover {
		color: var(--color-accent);
	}

	.related-guide-card p:last-child {
		margin-bottom: 0;
		color: var(--color-secondary);
		font-size: 0.9375rem;
	}

	@media (max-width: 768px) {
		.guide-tool-strip {
			align-items: stretch;
			flex-direction: column;
		}

		.guide-tool-strip .button {
			width: 100%;
		}

		.related-guides-head {
			align-items: start;
			flex-direction: column;
		}

		.related-guides-grid {
			grid-template-columns: 1fr;
		}

		.guide-related-tools-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
