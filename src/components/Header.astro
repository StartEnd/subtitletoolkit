---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav>
		<a class="logo" href="/">
			<svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" aria-hidden="true">
				<rect width="32" height="32" rx="8" fill="var(--color-accent)"/>
				<rect x="7" y="8" width="18" height="16" rx="4" fill="white" opacity="0.95"/>
				<path d="M11 13h10" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round"/>
				<path d="M11 16.5h6" stroke="var(--color-tertiary)" stroke-width="2" stroke-linecap="round"/>
				<path d="M11 20h8" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round"/>
			</svg>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/tools">Tools</HeaderLink>
			<HeaderLink href="/guides">Guides</HeaderLink>
		</div>
		<a class="header-cta" href="/tools">Use Tools <span aria-hidden="true">&rarr;</span></a>

		<button class="mobile-toggle" type="button" aria-label="Toggle menu" data-menu-toggle>
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
		</button>
	</nav>

	<div class="mobile-menu" data-mobile-menu>
		<HeaderLink href="/tools">Tools</HeaderLink>
		<HeaderLink href="/guides">Guides</HeaderLink>
		<a class="header-cta" href="/tools">Use Tools &rarr;</a>
	</div>
</header>

<script>
	const toggle = document.querySelector('[data-menu-toggle]');
	const menu = document.querySelector('[data-mobile-menu]');
	if (toggle && menu) {
		toggle.addEventListener('click', () => {
			menu.classList.toggle('is-open');
		});
	}
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0 1.5rem;
		background: var(--color-surface);
		border-bottom: 1px solid var(--color-subtle);
	}

	nav {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		max-width: var(--max-width);
		margin: 0 auto;
		height: 64px;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--color-base);
		flex-shrink: 0;
	}

	.logo:hover {
		color: var(--color-base);
	}

	.logo-icon {
		width: 28px;
		height: 28px;
	}

	.logo-text {
		font-size: 0.9375rem;
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		margin-left: auto;
	}

	.header-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-sm);
		background: var(--color-accent);
		color: white;
		font-size: 0.8125rem;
		font-weight: 600;
		text-decoration: none;
		flex-shrink: 0;
		transition: background var(--duration-fast) var(--ease);
	}

	.header-cta:hover {
		background: var(--color-accent-hover);
		color: white;
	}

	.mobile-toggle {
		display: none;
		border: none;
		background: none;
		padding: 0.5rem;
		color: var(--color-base);
		cursor: pointer;
	}

	.mobile-menu {
		display: none;
	}

	@media (max-width: 768px) {
		.nav-links,
		.header-cta {
			display: none;
		}

		.mobile-toggle {
			display: flex;
			margin-left: auto;
		}

		.mobile-menu {
			display: none;
			flex-direction: column;
			gap: 0;
			padding: 0.5rem 0 1rem;
			max-width: var(--max-width);
			margin: 0 auto;
		}

		.mobile-menu.is-open {
			display: flex;
		}

		.mobile-menu :global(a) {
			display: block;
			padding: 0.75rem 0;
			color: var(--color-base);
			text-decoration: none;
			font-weight: 500;
			font-size: 0.9375rem;
			border-bottom: 1px solid var(--color-subtle);
		}

		.mobile-menu .header-cta {
			display: inline-flex;
			margin-top: 0.75rem;
			border-bottom: none;
		}
	}
</style>
