---
import { SITE_DOMAIN, SITE_TITLE, SUPPORT_EMAIL } from '../consts';

const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-brand">
			<p class="footer-name">{SITE_TITLE}</p>
			<p class="footer-tagline">Free browser-based subtitle tools. No signup, no server upload.</p>
		</div>
		<div class="footer-columns">
			<div class="footer-col">
				<p class="footer-col-title">Tools</p>
				<a href="/tools/srt-to-vtt">SRT to VTT</a>
				<a href="/tools/vtt-to-srt">VTT to SRT</a>
				<a href="/tools/srt-to-ass">SRT to ASS</a>
				<a href="/tools/subtitle-time-shifter">Time Shifter</a>
				<a href="/tools/subtitle-cleaner">Cleaner</a>
			</div>
			<div class="footer-col">
				<p class="footer-col-title">Resources</p>
				<a href="/guides">Guides</a>
				<a href="/privacy-policy">Privacy Policy</a>
				<a href="/terms-of-service">Terms of Service</a>
				<a href={`mailto:${SUPPORT_EMAIL}`}>Support</a>
			</div>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.</p>
		<p>{SITE_DOMAIN}</p>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--color-base);
		padding: var(--space-12) 1.5rem var(--space-6);
		color: var(--color-tertiary);
	}

	.footer-inner {
		display: flex;
		gap: var(--space-16);
		max-width: var(--max-width);
		margin: 0 auto;
		padding-bottom: var(--space-8);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}

	.footer-brand {
		flex: 1;
		min-width: 200px;
	}

	.footer-name {
		color: white;
		font-weight: 700;
		font-size: 0.9375rem;
		margin-bottom: var(--space-2);
	}

	.footer-tagline {
		color: var(--color-tertiary);
		font-size: 0.8125rem;
		line-height: 1.5;
		margin: 0;
	}

	.footer-columns {
		display: flex;
		gap: var(--space-12);
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.footer-col-title {
		color: var(--color-secondary);
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: var(--space-1);
	}

	.footer-col a {
		color: var(--color-tertiary);
		text-decoration: none;
		font-size: 0.8125rem;
		transition: color var(--duration-fast) var(--ease);
	}

	.footer-col a:hover {
		color: white;
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		max-width: var(--max-width);
		margin: var(--space-6) auto 0;
		font-size: 0.75rem;
		color: var(--color-workspace-muted);
	}

	.footer-bottom p {
		margin: 0;
	}

	@media (max-width: 768px) {
		.footer-inner {
			flex-direction: column;
			gap: var(--space-8);
		}

		.footer-columns {
			gap: var(--space-8);
		}

		.footer-bottom {
			flex-direction: column;
			gap: var(--space-2);
			align-items: flex-start;
		}
	}
</style>
