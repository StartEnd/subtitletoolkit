---
import SiteLayout from '../layouts/SiteLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import JsonLd from './JsonLd.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import {
	guideCategoryMeta,
	guideCategoryOrder,
	type GuideCategory,
} from '../lib/guides/catalog';
import { SITE_DOMAIN, SITE_TITLE } from '../consts';

interface Props {
	category: GuideCategory;
	intro: string;
}

const { category, intro } = Astro.props;
const meta = guideCategoryMeta[category];

type GuideEntry = CollectionEntry<'guides'>;

const allGuides = (await getCollection('guides')).sort(
	(a: GuideEntry, b: GuideEntry) =>
		b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const guides = allGuides.filter(
	(guide: GuideEntry) => guide.data.category === category,
);

const otherCategories = guideCategoryOrder
	.filter((c) => c !== category)
	.map((c) => ({
		category: c,
		meta: guideCategoryMeta[c],
		count: allGuides.filter(
			(g: GuideEntry) => g.data.category === c,
		).length,
	}))
	.filter((entry) => entry.count > 0);

const pageTitle = `${meta.label} | ${SITE_TITLE}`;
const pageDescription = intro;
const hubCopy: Record<GuideCategory, { title: string; body: string; bullets: string[] }> = {
	'conversion-guides': {
		title: 'Use these guides when the destination format is the problem',
		body:
			'Conversion questions usually start with a working subtitle file that is not accepted by the next platform, editor, or player. These guides explain what changes between SRT, VTT, and ASS so you can convert the file intentionally instead of guessing from the extension alone.',
		bullets: [
			'Prepare captions for HTML5 video, YouTube uploads, legacy editors, and browser players.',
			'Understand what happens to timestamps, headers, cue numbers, and styling during conversion.',
			'Choose the matching browser tool after you know the source and destination format.',
		],
	},
	'sync-fixes': {
		title: 'Use these guides when subtitle timing or structure is broken',
		body:
			'Sync problems are easier to fix when you first identify the pattern: a global delay, a changed scene, malformed timestamps, out-of-order cues, or formatting that a player rejects. These guides help you choose the smallest repair before editing the whole file by hand.',
		bullets: [
			'Diagnose whether captions are early, late, drifting, or broken only in one section.',
			'Clean malformed SRT and WebVTT structures before converting or uploading.',
			'Use global and partial time shifting only when the timing pattern matches the fix.',
		],
	},
	'format-comparisons': {
		title: 'Use these guides before choosing a delivery format',
		body:
			'Format comparisons are useful when more than one subtitle file type could work. The right answer changes depending on whether the final target is a browser player, YouTube, Plex, Vimeo, JW Player, a client handoff, or an editing workflow.',
		bullets: [
			'Compare SRT, VTT, and ASS by compatibility, styling, browser support, and upload behavior.',
			'Pick a final delivery format without losing the editable source format too early.',
			'Use platform-specific guidance when generic format advice is too broad.',
		],
	},
	'workflow-guides': {
		title: 'Use these guides for end-to-end subtitle jobs',
		body:
			'Workflow guides cover practical jobs that involve more than one format decision, such as preparing captions for YouTube, extracting subtitles from video files, building bilingual subtitles, or cleaning files before delivery.',
		bullets: [
			'Follow a complete subtitle preparation path from source file to final upload.',
			'Handle privacy-sensitive browser-local workflows without sending files to a server.',
			'Combine conversion, cleanup, timing, and review steps in the right order.',
		],
	},
};

const currentHubCopy = hubCopy[category];

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Guides', href: '/guides/' },
	{ label: meta.label },
];
---

<SiteLayout title={pageTitle} description={pageDescription}>
	<JsonLd
		type="collectionPage"
		data={{
			'@type': 'CollectionPage',
			name: meta.label,
			description: pageDescription,
			url: `https://${SITE_DOMAIN}${meta.hubPath}`,
			mainEntity: {
				'@type': 'ItemList',
				itemListElement: guides.map((guide) => ({
					url: `https://${SITE_DOMAIN}/guides/${guide.id}/`,
					name: guide.data.title,
					description: guide.data.description,
				})),
			},
		}}
	/>
	<section class="section">
		<Breadcrumbs items={breadcrumbItems} />
		<span class="eyebrow">Guide cluster</span>
		<h1>{meta.label} <span class="hub-count">({guides.length})</span></h1>
		<p class="lede">{intro}</p>
	</section>

	<section class="section-muted">
		<div class="section-inner">
			<section class="hub-intro-copy" aria-labelledby="hub-intro-title">
				<div>
					<span class="eyebrow">How to choose</span>
					<h2 id="hub-intro-title">{currentHubCopy.title}</h2>
				</div>
				<p>{currentHubCopy.body}</p>
				<ul>
					{currentHubCopy.bullets.map((item) => <li>{item}</li>)}
				</ul>
			</section>

			<div class="card-grid">
				{
					guides.map((guide) => (
						<article class="card">
							<p class="hub-card-meta">
								{guide.data.primaryTool ? 'Mapped to a tool' : 'Reference guide'}
							</p>
							<h3>
								<a href={`/guides/${guide.id}/`}>{guide.data.title}</a>
							</h3>
							<p class="muted">{guide.data.description}</p>
							<a class="card-link" href={`/guides/${guide.id}/`}>
								Read guide <span aria-hidden="true">&rarr;</span>
							</a>
						</article>
					))
				}
			</div>
		</div>
	</section>

	{
		otherCategories.length > 0 && (
			<section class="section">
				<span class="eyebrow">Other clusters</span>
				<h2>Browse the rest of the guide library</h2>
				<div class="hub-other-grid">
					{otherCategories.map((entry) => (
						<a class="hub-other-card" href={entry.meta.hubPath}>
							<p class="hub-other-meta">{entry.count} guides</p>
							<h3>{entry.meta.label}</h3>
							<p>{entry.meta.description}</p>
							<span class="hub-other-link">
								Open cluster <span aria-hidden="true">&rarr;</span>
							</span>
						</a>
					))}
				</div>
			</section>
		)
	}
</SiteLayout>

<style>
	.hub-count {
		color: var(--color-tertiary);
		font-size: 0.7em;
		font-weight: 600;
	}

	.hub-card-meta {
		margin: 0 0 var(--space-2);
		color: var(--color-tertiary);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.hub-other-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-4);
		margin-top: var(--space-6);
	}

	.hub-other-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding: var(--space-5);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-background);
		color: var(--color-primary);
		text-decoration: none;
		transition: border-color 0.2s ease, transform 0.2s ease;
	}

	.hub-other-card:hover {
		border-color: var(--color-accent);
		transform: translateY(-1px);
	}

	.hub-other-meta {
		margin: 0;
		color: var(--color-tertiary);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.hub-other-card h3 {
		margin: 0;
		font-size: 1.05rem;
	}

	.hub-other-card p {
		margin: 0;
		color: var(--color-secondary);
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.hub-other-link {
		margin-top: var(--space-2);
		color: var(--color-accent);
		font-size: 0.875rem;
		font-weight: 600;
	}

	.hub-intro-copy {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		max-width: 58rem;
		margin-bottom: var(--space-8);
	}

	.hub-intro-copy p {
		color: var(--color-secondary);
		line-height: 1.7;
	}

	.hub-intro-copy ul {
		margin: 0;
		padding-left: var(--space-5);
	}

	.hub-intro-copy li {
		color: var(--color-secondary);
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.hub-other-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
