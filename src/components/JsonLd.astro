---
export type JsonLdType = 'website' | 'softwareApplication' | 'article' | 'faqPage' | 'collectionPage';

interface WebsiteData {
  '@type': 'WebSite';
  name: string;
  description: string;
  url: string;
}

interface SoftwareApplicationData {
  '@type': 'SoftwareApplication';
  name: string;
  description: string;
  url: string;
  applicationCategory: 'UtilityApplication';
  operatingSystem: 'Web Browser';
  offers?: {
    '@type': 'Offer';
    price: '0';
    priceCurrency: 'USD';
  };
}

interface ArticleData {
  '@type': 'Article';
  headline: string;
  description: string;
  datePublished: string;
  dateModified?: string;
  author?: {
    '@type': 'Organization';
    name: string;
  };
  publisher?: {
    '@type': 'Organization';
    name: string;
    logo?: {
      '@type': 'ImageObject';
      url: string;
    };
  };
}

interface FAQPageData {
  '@type': 'FAQPage';
  mainEntity: {
    '@type': 'Question';
    name: string;
    acceptedAnswer: {
      '@type': 'Answer';
      text: string;
    };
  }[];
}

interface CollectionPageItem {
  url: string;
  name: string;
  description?: string;
}

interface CollectionPageData {
  '@type': 'CollectionPage';
  name: string;
  description: string;
  url: string;
  mainEntity: {
    '@type': 'ItemList';
    itemListElement: CollectionPageItem[];
  };
}

type Props =
  | { type: 'website'; data: WebsiteData }
  | { type: 'softwareApplication'; data: SoftwareApplicationData }
  | { type: 'article'; data: ArticleData }
  | { type: 'faqPage'; data: FAQPageData }
  | { type: 'collectionPage'; data: CollectionPageData };

const { type, data } = Astro.props;

const jsonLd =
  type === 'collectionPage'
    ? {
        '@context': 'https://schema.org',
        '@type': 'CollectionPage',
        name: data.name,
        description: data.description,
        url: data.url,
        mainEntity: {
          '@type': 'ItemList',
          itemListElement: data.mainEntity.itemListElement.map((item, idx) => ({
            '@type': 'ListItem',
            position: idx + 1,
            url: item.url,
            name: item.name,
            ...(item.description ? { description: item.description } : {}),
          })),
        },
      }
    : {
        '@context': 'https://schema.org',
        ...data,
      };
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd, null, 2)}></script>
