---
import SiteLayout from '../../layouts/SiteLayout.astro';
import ToolWorkbench from '../../components/ToolWorkbench.astro';
import JsonLd from '../../components/JsonLd.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE_TITLE } from '../../consts';
import { getSubtitleCatalog, getSubtitleTool } from '../../lib/subtitles/catalog';

export async function getStaticPaths() {
	const catalog = getSubtitleCatalog('en');
	return catalog.tools.map((tool) => ({
		params: { slug: tool.id },
		props: { toolId: tool.id },
	}));
}

const catalog = getSubtitleCatalog('en');
const toolId = Astro.props.toolId ?? Astro.params.slug ?? '';
const currentTool = getSubtitleTool('en', toolId);

if (!currentTool) {
	return Astro.redirect('/tools/');
}

const relatedTools = currentTool.relatedTools
	.map((id) => getSubtitleTool('en', id))
	.filter(Boolean);

const toolMetaDescriptions: Record<string, string> = {
	'srt-to-vtt':
		'Convert SRT subtitles to VTT WebVTT online for free. Upload or paste an .srt file, convert it to .vtt, and download instantly.',
	'vtt-to-srt':
		'Convert VTT WebVTT captions to SRT subtitle files online for free. Upload or paste a .vtt file, convert it to .srt, and download instantly.',
	'srt-to-txt':
		'Convert SRT subtitles to plain text online for free. Remove timestamps and cue numbers, then copy or download clean TXT output.',
	'vtt-to-txt':
		'Convert VTT WebVTT captions to plain text online for free. Remove headers, timestamps, and cue settings from a .vtt file.',
	'srt-to-ass':
		'Convert SRT subtitles to ASS format with a clean default style, ready for subtitle editors, timing review, and styling workflows.',
	'ass-to-srt':
		'Convert ASS subtitles to SRT online for free. Flatten styled ASS dialogue into simple SubRip captions for uploads, review, and compatibility.',
	'vtt-to-ass':
		'Convert WebVTT captions to ASS format for subtitle editing and style-ready workflows, locally in your browser with no upload.',
	'ass-to-vtt':
		'Convert ASS subtitles to WebVTT for browser playback and HTML5 video delivery while keeping subtitle timing and readable text.',
	'subtitle-time-shifter':
		'Shift subtitle timing online for SRT, VTT, and ASS files. Fix subtitles that are too early or too late without signup or upload.',
	'subtitle-cleaner':
		'Clean SRT, VTT, and ASS subtitle text by removing stray tags, normalizing spacing, preserving cue timing, and preparing files for upload.',
	'subtitle-encoding-fixer':
		'Fix garbled subtitles online by converting SRT, VTT, ASS, SSA, and SMI files to clean UTF-8 text locally in your browser.',
	'subtitle-merger':
		'Merge two SRT, VTT, or ASS subtitle files into one sorted output file locally in your browser, with no account or server upload.',
	'partial-subtitle-shifter':
		'Shift only a selected time range inside an SRT, VTT, or ASS subtitle file without moving the rest of the captions, locally in your browser.',
	'extract-subtitles-from-video':
		'Extract embedded text subtitle tracks from MKV, MP4, MOV, and WebM files locally in your browser with FFmpeg and no upload.',
};

const toolPageTitles: Record<string, string> = {
	'srt-to-vtt': 'SRT to VTT Converter - Convert Subtitles Online Free',
	'vtt-to-srt': 'VTT to SRT Converter - Convert Subtitles Online Free',
	'srt-to-txt': 'SRT to TXT Converter - Extract Subtitle Text Online',
	'vtt-to-txt': 'VTT to TXT Converter - Extract Caption Text Online',
	'ass-to-srt': 'ASS to SRT Converter - Convert Subtitles Online Free',
	'subtitle-time-shifter': 'Subtitle Time Shifter - Fix Subtitle Delay Online',
	'subtitle-encoding-fixer': 'Subtitle Encoding Fixer - Fix Garbled Subtitles Online',
};

const workflowNotes: Record<string, string> = {
	'srt-to-vtt':
		'SRT is common for handoff, but browser players usually expect WebVTT. This converter adds the WEBVTT header, changes timestamp commas to dots, and removes SRT cue numbers so the file is ready for HTML5 video.',
	'vtt-to-srt':
		'WebVTT is ideal for browsers, but many subtitle editors, archive tools, and review workflows still ask for SRT. This converter removes the WEBVTT wrapper and adds numbered cue blocks.',
	'srt-to-txt':
		'Use SRT to TXT when you need the spoken subtitle text without timing metadata. The converter parses SRT cue blocks, removes cue numbers and timestamps, and exports the readable text for review, translation, or notes.',
	'vtt-to-txt':
		'Use VTT to TXT when captions come from a browser player or web workflow but the next step only needs readable text. The converter removes the WEBVTT header, cue timing, and browser-specific cue settings.',
	'srt-to-ass':
		'SRT is plain and portable. ASS is useful when the next step involves subtitle styling, karaoke timing, or an editor that expects an ASS structure. This tool creates a clean default ASS file from simple cue text.',
	'ass-to-srt':
		'ASS files can carry styling, position, and dialogue metadata. SRT is better when the destination needs simple timed text. This converter keeps timing and readable dialogue while flattening style-specific markup.',
	'vtt-to-ass':
		'Use this when captions begin in a web player workflow but need to move into an editor that works better with ASS. The output gives you a basic ASS structure that can be styled afterward.',
	'ass-to-vtt':
		'ASS is not the safest final format for browser playback. This converter creates WebVTT output so the same subtitle text can be used in HTML5 video and web player workflows.',
	'subtitle-time-shifter':
		'Use a global shift when every subtitle cue is off by the same amount. Positive milliseconds delay captions; negative milliseconds move them earlier. The tool preserves the detected subtitle format.',
	'subtitle-cleaner':
		'Cleaning is useful before upload, review, or conversion. The tool keeps cue timing intact while removing stray inline tags and normalizing subtitle text that often breaks player imports.',
	'subtitle-encoding-fixer':
		'Encoding problems usually show up as mojibake, broken accents, or unreadable non-English text. Choose the likely source encoding, then export a UTF-8 file for modern editors and video platforms.',
	'subtitle-merger':
		'Merging helps when subtitles were exported in parts or when two timed text files need one final delivery file. The output is sorted by start time, and SRT output is renumbered.',
	'partial-subtitle-shifter':
		'Use a partial shift when only a middle section changed after an edit. Cues outside the selected range keep their original timing, which avoids breaking sections that already match the video.',
	'extract-subtitles-from-video':
		'This tool is for embedded text subtitle streams, not burned-in subtitles. It runs FFmpeg in the browser and attempts to save the first subtitle stream as a separate subtitle file.',
};

const mistakeNotes: Record<string, string[]> = {
	'srt-to-vtt': [
		'Missing the WEBVTT header after conversion.',
		'Keeping comma-based SRT timestamps in a browser VTT file.',
		'Uploading a subtitle file before checking cue text in the target player.',
	],
	'vtt-to-srt': [
		'Leaving WebVTT notes or metadata in a workflow that expects plain SRT.',
		'Forgetting that SRT uses comma-based milliseconds.',
		'Assuming every legacy editor understands WebVTT cue settings.',
	],
	'srt-to-txt': [
		'Using plain text output when the next step still needs subtitle timing.',
		'Deleting the original SRT file before confirming the transcript text is enough.',
		'Expecting TXT output to preserve cue numbers or timestamps.',
	],
	'vtt-to-txt': [
		'Using plain text output when the destination still needs WebVTT timing.',
		'Deleting the original VTT file before checking the exported text.',
		'Expecting WebVTT cue settings to appear in the TXT output.',
	],
	'srt-to-ass': [
		'Expecting advanced styling to appear automatically from a plain SRT source.',
		'Forgetting to review line breaks after conversion.',
		'Delivering ASS to a platform that only wants SRT or VTT.',
	],
	'ass-to-srt': [
		'Expecting ASS positioning, colors, or effects to survive in SRT.',
		'Not reviewing dialogue lines that used complex override tags.',
		'Using SRT when the destination still requires styled subtitles.',
	],
	'vtt-to-ass': [
		'Expecting VTT cue settings to become styled ASS rules automatically.',
		'Forgetting to review the default ASS style before final delivery.',
		'Using ASS as the final file for a browser player that expects VTT.',
	],
	'ass-to-vtt': [
		'Expecting ASS styling and positioning to render in WebVTT.',
		'Forgetting to test the output in the actual web player.',
		'Leaving complex styled dialogue unreviewed after flattening.',
	],
	'subtitle-time-shifter': [
		'Using a global shift when only one section is out of sync.',
		'Entering seconds when the tool expects milliseconds.',
		'Applying the wrong sign: positive delays captions, negative moves them earlier.',
	],
	'subtitle-cleaner': [
		'Cleaning text before saving a backup of the original file.',
		'Assuming cleanup can repair badly timed subtitles.',
		'Leaving malformed timestamps for the video platform to reject later.',
	],
	'subtitle-encoding-fixer': [
		'Choosing UTF-8 as the source when the file was saved as Windows-1252 or another legacy encoding.',
		'Re-saving garbled text instead of reopening from the original file.',
		'Confusing encoding problems with missing fonts in a player.',
	],
	'subtitle-merger': [
		'Merging files with overlapping cue ranges without reviewing the result.',
		'Mixing formats when a same-format merge would be safer.',
		'Forgetting to check cue order after joining separate exports.',
	],
	'partial-subtitle-shifter': [
		'Setting a range that does not include the cue start times you want to move.',
		'Using a partial shift when the whole file is offset by the same amount.',
		'Forgetting to review the cue just before and after the edited section.',
	],
	'extract-subtitles-from-video': [
		'Expecting burned-in subtitles to be extracted as text.',
		'Assuming every embedded subtitle stream can be converted to SRT.',
		'Uploading a very large video before confirming it actually contains a text subtitle track.',
	],
};

const supportedFormatText = currentTool.acceptedExtensions.join(', ');
const metaDescription = toolMetaDescriptions[currentTool.id] ?? currentTool.description;
const pageTitle = toolPageTitles[currentTool.id] ?? `${currentTool.title} | ${SITE_TITLE}`;

const isConversionTool = ![
	'subtitle-time-shifter',
	'subtitle-cleaner',
	'subtitle-encoding-fixer',
	'subtitle-merger',
	'partial-subtitle-shifter',
	'extract-subtitles-from-video',
].includes(currentTool.id);

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Tools', href: '/tools/' },
	{ label: currentTool.shortTitle },
];
---

<SiteLayout title={pageTitle} description={metaDescription}>
		<JsonLd type="softwareApplication" data={{
			'@type': 'SoftwareApplication',
			name: currentTool.title,
			description: metaDescription,
			url: `https://subtitletoolkit.tools/tools/${currentTool.id}/`,
			applicationCategory: 'UtilityApplication',
			operatingSystem: 'Web Browser',
			offers: {
				'@type': 'Offer',
				price: '0',
				priceCurrency: 'USD',
			},
		}} />
		<JsonLd type="faqPage" data={{
			'@type': 'FAQPage',
			mainEntity: currentTool.faqs.map((faq) => ({
				'@type': 'Question',
				name: faq.question,
				acceptedAnswer: {
					'@type': 'Answer',
					text: faq.answer,
				},
			})),
		}} />
	<section class="section" style="padding-bottom: 0;">
		<Breadcrumbs items={breadcrumbItems} />
	</section>
	<!-- Tool Header -->
	<section class="section tool-header">
		<span class="eyebrow">{isConversionTool ? 'Format conversion' : 'Subtitle utility'}</span>
		<h1>{currentTool.title}</h1>
		<p class="lede">{currentTool.description}</p>
		<div class="badge-row" style="margin-top: var(--space-4);">
			<span class="trust-badge">Free</span>
			<span class="trust-badge">No signup</span>
			<span class="trust-badge">Browser-local</span>
		</div>
	</section>

	<!-- Workspace -->
	<section class="section" style="padding-top: 0;">
		<ToolWorkbench tool={currentTool} labels={catalog.pageLabels} />
	</section>

	<!-- Info Grid -->
	<section class="section-muted">
		<div class="section-inner">
			<section class="tool-seo-copy" aria-labelledby="tool-workflow-title">
				<div>
					<span class="eyebrow">Workflow notes</span>
					<h2 id="tool-workflow-title">How to use this {currentTool.shortTitle} tool</h2>
				</div>
				<p>{workflowNotes[currentTool.id]}</p>
				<p>
					Start by uploading or pasting a supported file ({supportedFormatText}). Check the sample input if you want to see the expected structure first, then run the conversion or repair step and review the output before downloading it. The tool is designed for quick subtitle jobs where opening a full video editor would be unnecessary.
				</p>
				<div class="tool-seo-columns">
					<div>
						<h3>Input and output checklist</h3>
						<ul>
							<li>Use a complete subtitle file with valid cue timing when possible.</li>
							<li>Keep a copy of the original file before replacing it in your workflow.</li>
							<li>Review the first few cues, the middle of the file, and the final cue after export.</li>
							<li>Test the downloaded output in the destination player, editor, or upload form.</li>
						</ul>
					</div>
					<div>
						<h3>Common mistakes to avoid</h3>
						<ul>
							{mistakeNotes[currentTool.id].map((note) => <li>{note}</li>)}
						</ul>
					</div>
				</div>
				<p>
					All processing runs in your browser, so the subtitle or video file does not need to be uploaded to a server. That is useful for client review files, unreleased videos, internal training material, and other caption workflows where the text should stay on your device.
				</p>
			</section>

			<div class="info-grid">
				<!-- Use Cases -->
				<article class="info-card">
					<h2>{catalog.pageLabels.useCasesTitle}</h2>
					<p class="muted" style="margin-bottom: var(--space-4);">{currentTool.summary}</p>
					<ul>
						{currentTool.useCases.map((useCase) => <li>{useCase}</li>)}
					</ul>
				</article>

				<!-- FAQ -->
				<article class="info-card">
					<h2>{catalog.pageLabels.faqTitle}</h2>
					<div class="faq-list">
						{
							currentTool.faqs.map((faq) => (
								<details class="faq-item">
									<summary class="faq-question">
										{faq.question}
										<span class="faq-icon">+</span>
									</summary>
									<div class="faq-answer">
										<p>{faq.answer}</p>
									</div>
								</details>
							))
						}
					</div>
				</article>

				<!-- Related -->
				<article class="info-card">
					<h2>{catalog.pageLabels.relatedToolsTitle}</h2>
					<ul>
						{
							relatedTools.map((tool) => (
								<li><a href={`/tools/${tool?.id}/`}>{tool?.title}</a></li>
							))
						}
					</ul>
					<h2 style="margin-top: var(--space-6);">{catalog.pageLabels.relatedGuidesTitle}</h2>
					<ul>
						{
							currentTool.relatedGuides.map((guide) => (
								<li><a href={guide.href}>{guide.title}</a></li>
							))
						}
					</ul>
				</article>
			</div>

			<!-- Ad slot placeholder -->
			<div class="ad-slot"></div>
		</div>
	</section>
</SiteLayout>

<style>
	.tool-header {
		padding-bottom: var(--space-4);
	}

	.tool-header h1 {
		margin-bottom: var(--space-3);
	}

	/* FAQ in info card context */
	.info-card .faq-list {
		display: flex;
		flex-direction: column;
	}

	.info-card .faq-item {
		border-bottom-color: var(--color-subtle);
	}

	.info-card .faq-question {
		font-size: 0.875rem;
		padding: var(--space-3) 0;
	}

	.info-card .faq-answer {
		padding: 0 0 var(--space-3) 0;
		font-size: 0.8125rem;
	}

	.info-card .faq-answer p {
		margin: 0;
	}

	.tool-seo-copy {
		display: flex;
		flex-direction: column;
		gap: var(--space-5);
		max-width: 64rem;
		margin-bottom: var(--space-10);
	}

	.tool-seo-copy p {
		max-width: 58rem;
		color: var(--color-secondary);
		line-height: 1.7;
	}

	.tool-seo-columns {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-6);
	}

	.tool-seo-columns h3 {
		font-size: 1rem;
	}

	.tool-seo-columns ul {
		margin: var(--space-3) 0 0;
		padding-left: var(--space-5);
	}

	.tool-seo-columns li {
		color: var(--color-secondary);
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.tool-seo-columns {
			grid-template-columns: 1fr;
		}
	}

	/* Related links */
	.info-card a {
		color: var(--color-accent);
		font-size: 0.875rem;
		font-weight: 500;
		text-decoration: none;
	}

	.info-card a:hover {
		color: var(--color-accent-hover);
		text-decoration: underline;
	}
</style>
