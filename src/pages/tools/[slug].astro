	{
		name: 'Add a supported subtitle file',
		text: `Upload or paste a supported subtitle file (${supportedFormatText}), or load the sample input to see the expected structure.`,
	},
	{
		name: `Run the ${currentTool.shortTitle} tool`,
		text: 'Use the browser-based converter or repair action to process the subtitle file locally on your device.',
	},
	{
		name: 'Review and download the output',
		text: 'Check the first few cues, the middle of the file, and the final cue before copying or downloading the result.',
	},
];

const isConversionTool = ![
	'youtube-subtitle-converter',
	'html5-video-subtitle-converter',
	'videojs-subtitle-converter',
	'jw-player-subtitle-converter',
	'plex-subtitle-converter',
	'vimeo-subtitle-converter',
	'subtitle-time-shifter',
	'subtitle-delay-fixer',
	'fix-out-of-sync-subtitles',
	'subtitle-cleaner',
	'clean-srt-file',
	'remove-srt-line-numbers',
	'fix-srt-timestamps',
	'srt-validator',
	'webvtt-validator',
	'subtitle-transcript-generator',
	'subtitle-encoding-fixer',
	'subtitle-merger',
	'partial-subtitle-shifter',
	'extract-subtitles-from-video',
].includes(currentTool.id);

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Tools', href: '/tools/' },
	{ label: currentTool.shortTitle },
];
---

<SiteLayout title={pageTitle} description={metaDescription}>
		<JsonLd type="softwareApplication" data={{
			'@type': 'SoftwareApplication',
			name: currentTool.title,
			description: metaDescription,
			url: `https://subtitletoolkit.tools/tools/${currentTool.id}/`,
			applicationCategory: 'UtilityApplication',
			operatingSystem: 'Web Browser',
			isAccessibleForFree: true,
			featureList: [
				'Runs locally in the browser',
				'No signup required',
				'No server upload required',
			],
			offers: {
				'@type': 'Offer',
				price: '0',
				priceCurrency: 'USD',
			},
		}} />
		<JsonLd type="faqPage" data={{
			'@type': 'FAQPage',
			mainEntity: currentTool.faqs.map((faq) => ({
				'@type': 'Question',
				name: faq.question,
				acceptedAnswer: {
					'@type': 'Answer',
					text: faq.answer,
				},
			})),
		}} />
		<JsonLd type="howTo" data={{
			'@type': 'HowTo',
			name: `How to use the ${currentTool.title}`,
			description: workflowNotes[currentTool.id],
			step: howToSteps.map((step) => ({
				'@type': 'HowToStep',
				...step,
			})),
		}} />
	<section class="section" style="padding-bottom: 0;">
		<Breadcrumbs items={breadcrumbItems} />
	</section>
	<!-- Tool Header -->
	<section class="section tool-header">
		<span class="eyebrow">{isConversionTool ? 'Format conversion' : 'Subtitle utility'}</span>
		<h1>{currentTool.title}</h1>
		<p class="lede">{currentTool.description}</p>
		<div class="badge-row" style="margin-top: var(--space-4);">
			<span class="trust-badge">Free</span>
			<span class="trust-badge">No signup</span>
			<span class="trust-badge">Browser-local</span>
		</div>
	</section>

	<!-- Workspace -->
	<section class="section" style="padding-top: 0;">
		<ToolWorkbench tool={currentTool} labels={catalog.pageLabels} />
	</section>

	<!-- Info Grid -->
	<section class="section-muted">
		<div class="section-inner">
			<section class="tool-seo-copy" aria-labelledby="tool-workflow-title">
				<div>
					<span class="eyebrow">Workflow notes</span>
					<h2 id="tool-workflow-title">How to use this {currentTool.shortTitle} tool</h2>
				</div>
				<p>{workflowNotes[currentTool.id]}</p>
				<ol>
					{howToSteps.map((step) => <li><strong>{step.name}.</strong> {step.text}</li>)}
				</ol>
				<div class="tool-seo-columns">
					<div>
						<h3>Input and output checklist</h3>
						<ul>
							<li>Use a complete subtitle file with valid cue timing when possible.</li>
							<li>Keep a copy of the original file before replacing it in your workflow.</li>
							<li>Review the first few cues, the middle of the file, and the final cue after export.</li>
							<li>Test the downloaded output in the destination player, editor, or upload form.</li>
						</ul>
					</div>
					<div>
						<h3>Common mistakes to avoid</h3>
						<ul>
							{mistakeNotes[currentTool.id].map((note) => <li>{note}</li>)}
						</ul>
					</div>
				</div>
				<p>
					All processing runs in your browser, so the subtitle or video file does not need to be uploaded to a server. That is useful for client review files, unreleased videos, internal training material, and other caption workflows where the text should stay on your device.
				</p>
			</section>

			<div class="info-grid">
				<!-- Use Cases -->
				<article class="info-card">
					<h2>{catalog.pageLabels.useCasesTitle}</h2>
					<p class="muted" style="margin-bottom: var(--space-4);">{currentTool.summary}</p>
					<ul>
						{currentTool.useCases.map((useCase) => <li>{useCase}</li>)}
					</ul>
				</article>

				<!-- FAQ -->
				<article class="info-card">
					<h2>{catalog.pageLabels.faqTitle}</h2>
					<div class="faq-list">
						{
							currentTool.faqs.map((faq) => (
								<details class="faq-item">
									<summary class="faq-question">
										{faq.question}
										<span class="faq-icon">+</span>
									</summary>
									<div class="faq-answer">
										<p>{faq.answer}</p>
									</div>
								</details>
							))
						}
					</div>
				</article>

				<!-- Related -->
				<article class="info-card">
					<h2>{catalog.pageLabels.relatedToolsTitle}</h2>
					<ul>
						{
							relatedTools.map((tool) => (
								<li><a href={`/tools/${tool?.id}/`}>{tool?.title}</a></li>
							))
						}
					</ul>
					<h2 style="margin-top: var(--space-6);">{catalog.pageLabels.relatedGuidesTitle}</h2>
					<ul>
						{
							currentTool.relatedGuides.map((guide) => (
								<li><a href={guide.href}>{guide.title}</a></li>
							))
						}
					</ul>
				</article>
			</div>

			<!-- Ad slot placeholder -->
			<div class="ad-slot" data-ad-slot="tool-below-workflow" aria-hidden="true"></div>
		</div>
	</section>
</SiteLayout>

<style>
	.tool-header {
		padding-bottom: var(--space-4);
	}

	.tool-header h1 {
		margin-bottom: var(--space-3);
	}

	/* FAQ in info card context */
	.info-card .faq-list {
		display: flex;
		flex-direction: column;
	}

	.info-card .faq-item {
		border-bottom-color: var(--color-subtle);
	}

	.info-card .faq-question {
		font-size: 0.875rem;
		padding: var(--space-3) 0;
	}

	.info-card .faq-answer {
		padding: 0 0 var(--space-3) 0;
		font-size: 0.8125rem;
	}

	.info-card .faq-answer p {
		margin: 0;
	}

	.tool-seo-copy {
		display: flex;
		flex-direction: column;
		gap: var(--space-5);
		max-width: 64rem;
		margin-bottom: var(--space-10);
	}

	.tool-seo-copy p {
		max-width: 58rem;
		color: var(--color-secondary);
		line-height: 1.7;
	}

	.tool-seo-columns {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-6);
	}

	.tool-seo-columns h3 {
		font-size: 1rem;
	}

	.tool-seo-columns ul {
		margin: var(--space-3) 0 0;
		padding-left: var(--space-5);
	}

	.tool-seo-columns li {
		color: var(--color-secondary);
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.tool-seo-columns {
			grid-template-columns: 1fr;
		}
	}

	/* Related links */
	.info-card a {
		color: var(--color-accent);
		font-size: 0.875rem;
		font-weight: 500;
		text-decoration: none;
	}

	.info-card a:hover {
		color: var(--color-accent-hover);
		text-decoration: underline;
	}
</style>
