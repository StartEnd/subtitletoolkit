import { getSubtitleCatalog, getSubtitleTool } from '../../lib/subtitles/catalog';

export async function getStaticPaths() {
	const catalog = getSubtitleCatalog('en');
	return catalog.tools.map((tool) => ({
		params: { slug: tool.id },
		props: { toolId: tool.id },
	}));
}

const catalog = getSubtitleCatalog('en');
const toolId = Astro.props.toolId ?? Astro.params.slug ?? '';
const currentTool = getSubtitleTool('en', toolId);

if (!currentTool) {
	return Astro.redirect('/tools/');
}

const relatedTools = currentTool.relatedTools
	.map((id) => getSubtitleTool('en', id))
	.filter(Boolean);

