---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getSubtitleCatalog } from '../../lib/subtitles/catalog';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const catalog = getSubtitleCatalog('en');
const conversionTools = catalog.tools.filter(t => !['subtitle-time-shifter', 'subtitle-cleaner'].includes(t.id));
const utilityTools = catalog.tools.filter(t => ['subtitle-time-shifter', 'subtitle-cleaner'].includes(t.id));
---

<SiteLayout title={`Tools | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<!-- Header -->
	<section class="section">
		<span class="eyebrow">Subtitle tools</span>
		<h1>Free browser-based tools for every subtitle job.</h1>
		<p class="lede">{catalog.toolsPage.description}</p>
	</section>

	<!-- Format Conversion -->
	<section class="section-muted">
		<div class="section-inner">
			<span class="eyebrow">Format conversion</span>
			<h2>Convert between SRT, VTT, and ASS</h2>
			<div class="card-grid" style="margin-top: var(--space-8);">
				{
					conversionTools.map((tool) => (
						<article class="card">
							<div class="badge-row">
								<span class="format-badge">{tool.shortTitle.split(' to ')[0]}</span>
								<span class="format-arrow">&rarr;</span>
								<span class="format-badge">{tool.shortTitle.split(' to ')[1]}</span>
							</div>
							<h3><a href={`/tools/${tool.id}`}>{tool.title}</a></h3>
							<p class="muted">{tool.description}</p>
							<a class="card-link" href={`/tools/${tool.id}`}>Open tool <span aria-hidden="true">&rarr;</span></a>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<!-- Subtitle Utilities -->
	<section class="section">
		<span class="eyebrow">Subtitle utilities</span>
		<h2>Fix timing and clean up formatting</h2>
		<div class="card-grid" style="margin-top: var(--space-8);">
			{
				utilityTools.map((tool) => (
					<article class="card">
						<div class="badge-row">
							<span class="format-badge">{tool.shortTitle}</span>
						</div>
						<h3><a href={`/tools/${tool.id}`}>{tool.title}</a></h3>
						<p class="muted">{tool.description}</p>
						<a class="card-link" href={`/tools/${tool.id}`}>Open tool <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<!-- Why browser-local -->
	<section class="section-muted">
		<div class="section-inner">
			<span class="eyebrow">Why browser-local</span>
			<h2>{catalog.toolsPage.whyLocalTitle}</h2>
			<ul class="why-list">
				{catalog.toolsPage.whyLocalItems.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		</div>
	</section>
</SiteLayout>

<style>
	.format-arrow {
		color: var(--color-tertiary);
		font-size: 0.75rem;
		font-weight: 600;
	}

	.why-list {
		max-width: 42rem;
		margin-top: var(--space-6);
		padding-left: var(--space-6);
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.why-list li {
		color: var(--color-secondary);
		font-size: 0.9375rem;
		line-height: 1.6;
	}
</style>
