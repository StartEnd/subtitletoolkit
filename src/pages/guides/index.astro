---
import SiteLayout from '../../layouts/SiteLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getCollection } from 'astro:content';
import { SITE_DOMAIN, SITE_TITLE } from '../../consts';
import { guideCategoryMeta, guideCategoryOrder } from '../../lib/guides/catalog';

const guides = (await getCollection('guides')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const groupedGuides = guideCategoryOrder
	.map((category) => ({
		category,
		meta: guideCategoryMeta[category],
		guides: guides.filter((guide) => guide.data.category === category),
	}))
	.filter((group) => group.guides.length > 0);
const priorityGuideIds = [
	'how-to-convert-srt-to-vtt-for-html5-video',
	'why-youtube-subtitles-upload-failed',
	'how-to-convert-subtitles-for-youtube',
	'how-to-fix-subtitle-delay',
	'why-srt-file-wont-upload',
	'why-subtitles-do-not-show-in-html5-video',
];
const formatDecisionGuideIds = [
	'srt-vs-vtt',
	'ass-vs-srt',
	'ass-vs-vtt',
	'when-webvtt-is-better-than-srt',
	'when-to-use-ass-instead-of-srt',
];
const platformGuideIds = [
	'why-videojs-captions-are-not-showing',
	'why-plyr-captions-are-not-showing',
	'why-jw-player-captions-are-not-showing',
	'why-vlc-subtitles-are-not-showing',
	'why-tv-subtitles-are-not-showing',
	'why-plex-subtitles-are-not-showing',
	'why-vimeo-captions-are-not-showing',
];
const playerConversionGuideIds = [
	'how-to-convert-subtitles-for-videojs',
	'how-to-convert-subtitles-for-jw-player',
	'how-to-convert-subtitles-for-plex',
	'how-to-convert-subtitles-for-vimeo',
];
const playerFormatGuideIds = [
	'best-subtitle-format-for-videojs',
	'best-subtitle-format-for-jw-player',
	'best-subtitle-format-for-plex',
	'best-subtitle-format-for-vimeo-embeds',
];
const transcriptWorkflowGuideIds = [
	'how-to-convert-subtitles-to-plain-text',
	'how-to-remove-timestamps-from-subtitles',
	'how-to-remove-timestamps-from-srt',
	'how-to-remove-timestamps-from-vtt',
	'how-to-convert-srt-to-txt',
	'how-to-convert-vtt-to-txt',
	'how-to-convert-ass-to-txt',
	'how-to-convert-ssa-to-txt',
	'how-to-create-a-transcript-from-subtitles',
	'how-to-create-dual-language-subtitles',
	'how-to-merge-two-srt-files',
];
const repairTriageGuideIds = [
	'common-subtitle-format-errors-and-fixes',
	'why-srt-file-is-not-working',
	'why-subtitles-are-missing-after-conversion',
	'why-converted-subtitle-file-is-empty',
	'why-subtitles-drift-out-of-sync',
	'how-to-fix-vlc-subtitle-delay',
	'how-to-fix-subtitles-that-are-too-long',
	'how-to-fix-subtitles-that-are-too-fast-or-too-slow',
	'how-to-fix-out-of-order-subtitle-cues',
	'how-to-fix-overlapping-subtitles',
	'how-to-fix-subtitle-line-breaks',
];
const encodingGuideIds = [
	'how-to-convert-subtitles-to-utf-8',
	'how-to-fix-garbled-subtitles',
	'how-to-fix-subtitles-showing-boxes',
	'subtitle-encoding-windows-1252-vs-utf-8',
];
const html5CaptionGuideIds = [
	'best-subtitle-format-for-html5-video',
	'how-to-convert-subtitles-for-html5-video',
	'why-iphone-subtitles-are-not-showing',
	'why-android-captions-are-not-showing',
	'why-chrome-captions-are-not-showing',
	'why-edge-captions-are-not-showing',
	'why-firefox-captions-are-not-showing',
	'why-safari-captions-are-not-showing',
	'why-plyr-captions-are-not-showing',
	'how-to-convert-ass-to-vtt-for-web-players',
	'how-to-add-multiple-subtitle-languages-to-html5-video',
];
const uploadPrepGuideIds = [
	'how-to-convert-srt-to-ssa',
	'how-to-convert-vtt-to-ssa',
	'how-to-convert-ass-to-srt',
	'how-to-convert-ass-to-srt-for-youtube-uploads',
	'how-to-export-srt-from-aegisub',
	'how-to-convert-ssa-to-srt',
	'how-to-convert-ssa-to-vtt',
	'how-to-clean-subtitle-formatting-before-upload',
	'how-to-validate-srt-files',
	'how-to-validate-webvtt-files',
];
const extractionGuideIds = [
	'how-to-extract-subtitles-from-video',
	'why-downloaded-video-has-no-subtitles',
	'how-to-extract-subtitles-from-mp4',
	'why-mp4-subtitles-are-not-showing',
	'how-to-extract-subtitles-from-m4v',
	'how-to-extract-subtitles-from-mkv',
	'why-mkv-subtitles-are-not-showing',
	'how-to-extract-subtitles-from-mov',
	'why-mov-subtitles-are-not-showing',
	'how-to-extract-subtitles-from-webm',
	'why-webm-subtitles-are-not-showing',
	'how-to-extract-subtitles-from-avi',
	'how-to-extract-subtitles-from-vob',
	'how-to-extract-subtitles-from-wmv',
	'embedded-vs-burned-in-subtitles',
];
const priorityGuides = priorityGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const formatDecisionGuides = formatDecisionGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const platformGuides = platformGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const playerConversionGuides = playerConversionGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const playerFormatGuides = playerFormatGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const transcriptWorkflowGuides = transcriptWorkflowGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const repairTriageGuides = repairTriageGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const encodingGuides = encodingGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const html5CaptionGuides = html5CaptionGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const uploadPrepGuides = uploadPrepGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const extractionGuides = extractionGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const pageDescription =
	'Read practical subtitle guides for format conversion, sync fixes, SRT vs VTT comparisons, YouTube uploads, HTML5 video, and browser caption workflows.';
---

<SiteLayout title={`Subtitle Guides and Format Fixes | ${SITE_TITLE}`} description={pageDescription}>
	<JsonLd
		type="collectionPage"
		data={{
			'@type': 'CollectionPage',
			name: 'Subtitle Guides',
			description: pageDescription,
			url: `https://${SITE_DOMAIN}/guides/`,
			mainEntity: {
				'@type': 'ItemList',
				itemListElement: groupedGuides.map((group) => ({
					url: `https://${SITE_DOMAIN}${group.meta.hubPath}`,
					name: group.meta.label,
					description: group.meta.description,
				})),
			},
		}}
	/>
	<section class="section">
		<span class="eyebrow">Guide archive</span>
		<h1>Guides for practical subtitle workflows.</h1>
		<p class="lede">
			Long-tail tutorials for subtitle conversion, repair, format decisions, and delivery workflows.
			Each guide is organized by job-to-be-done and links directly into a relevant tool.
		</p>
		<nav class="guide-nav" aria-label="Guide clusters">
			{
				groupedGuides.map((group) => (
					<a class="guide-nav-link" href={group.meta.hubPath}>
						{group.meta.label} <span>{group.guides.length}</span>
					</a>
				))
			}
		</nav>
	</section>

	<section class="section">
		<span class="eyebrow">Start here</span>
		<h2>High-intent subtitle problems to fix first.</h2>
		<p class="lede priority-lede">
			These guides match the searches most likely to turn into a tool action: convert a file,
			fix timing, clean a broken upload, or prepare captions for a specific platform.
		</p>
		<div class="priority-grid">
			{
				priorityGuides.map((guide) => (
					<article class="priority-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Read guide <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section">
		<span class="eyebrow">Format decisions</span>
		<h2>Choose the subtitle format before converting.</h2>
		<p class="lede priority-lede">
			Start here when the question is whether SRT, VTT, or ASS fits the destination before opening a converter.
		</p>
		<div class="priority-grid">
			{
				formatDecisionGuides.map((guide) => (
					<article class="priority-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Compare formats <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section">
		<span class="eyebrow">Platform caption fixes</span>
		<h2>Fix captions that fail in specific players.</h2>
		<p class="lede priority-lede">
			Start with the guide for the player that is failing, then use the linked converter or validator before changing the video embed.
		</p>
		<div class="platform-grid">
			{
				platformGuides.map((guide) => (
					<article class="platform-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Fix captions <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section">
		<span class="eyebrow">Player conversions</span>
		<h2>Convert captions before wiring them into a player.</h2>
		<p class="lede priority-lede">
			Start here when the subtitle file format is the risk before Video.js, JW Player, Plex, or Vimeo delivery.
		</p>
		<div class="platform-grid">
			{
				playerConversionGuides.map((guide) => (
					<article class="platform-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Convert captions <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section">
		<span class="eyebrow">Player format choices</span>
		<h2>Pick the safest subtitle format for each player.</h2>
		<p class="lede priority-lede">
			Start here when the question is whether Video.js, JW Player, Plex, or Vimeo needs SRT, VTT, or another delivery file.
		</p>
		<div class="platform-grid">
			{
				playerFormatGuides.map((guide) => (
					<article class="platform-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Choose format <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section">
		<span class="eyebrow">Transcript workflows</span>
		<h2>Extract readable text or combine subtitle files.</h2>
		<p class="lede priority-lede">
			Start here when the job is a clean transcript, translation handoff, or one merged subtitle file.
		</p>
		<div class="platform-grid">
			{
				transcriptWorkflowGuides.map((guide) => (
					<article class="platform-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Open workflow <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section">
		<span class="eyebrow">Subtitle repair triage</span>
		<h2>Diagnose messy files before changing timing.</h2>
		<p class="lede priority-lede">
			Start here when the file is broken, cues are out of order, or the timing problem might be drift instead of a simple delay.
		</p>
		<div class="platform-grid">
			{
				repairTriageGuides.map((guide) => (
					<article class="platform-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Diagnose issue <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section">
		<span class="eyebrow">Encoding fixes</span>
		<h2>Repair garbled subtitle text before upload.</h2>
		<p class="lede priority-lede">
			Start here when subtitles show broken accents, question marks, boxes, or old Windows encoding artifacts.
		</p>
		<div class="platform-grid">
			{
				encodingGuides.map((guide) => (
					<article class="platform-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Fix encoding <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section">
		<span class="eyebrow">HTML5 captions</span>
		<h2>Prepare WebVTT tracks for browser video.</h2>
		<p class="lede priority-lede">
			Start here when captions need to work in an HTML5 video tag, web player, or multilingual browser embed.
		</p>
		<div class="priority-grid">
			{
				html5CaptionGuides.map((guide) => (
					<article class="priority-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Prepare captions <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section">
		<span class="eyebrow">Upload prep</span>
		<h2>Clean and validate subtitle files before delivery.</h2>
		<p class="lede priority-lede">
			Start here when the file must survive a YouTube upload, client handoff, or player integration without hidden formatting errors.
		</p>
		<div class="priority-grid">
			{
				uploadPrepGuides.map((guide) => (
					<article class="priority-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Prepare file <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section">
		<span class="eyebrow">Subtitle extraction</span>
		<h2>Extract real subtitle tracks before trying OCR.</h2>
		<p class="lede priority-lede">
			Start here when a video file might contain selectable captions, embedded text tracks, or burned-in subtitles.
		</p>
		<div class="priority-grid extraction-grid">
			{
				extractionGuides.map((guide) => (
					<article class="priority-card">
						<p class="priority-card-meta">
							{guideCategoryMeta[guide.data.category].label}
						</p>
						<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
						<p>{guide.data.description}</p>
						<a class="card-link" href={`/guides/${guide.id}/`}>Extract subtitles <span aria-hidden="true">&rarr;</span></a>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-muted">
		<div class="section-inner">
			<div class="guide-clusters">
				{
					groupedGuides.map((group) => (
						<section class="guide-cluster" aria-labelledby={`cluster-${group.category}`}>
							<div class="guide-cluster-head">
								<div>
									<p class="guide-cluster-kicker">Cluster</p>
									<h2 id={`cluster-${group.category}`}>{group.meta.label} <span class="guide-cluster-count">({group.guides.length})</span></h2>
								</div>
								<p class="guide-cluster-description">{group.meta.description}</p>
							</div>
							<div class="card-grid">
								{
									group.guides.map((guide) => (
										<article class="card">
											<p class="guide-card-meta">
												{guide.data.primaryTool ? 'Mapped to a tool' : 'Reference guide'}
											</p>
											{
												guide.data.primaryTool && (
													<p class="guide-card-tool">Tool intent page</p>
												)
											}
											<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
											<p class="muted">{guide.data.description}</p>
											<a class="card-link" href={`/guides/${guide.id}/`}>Read guide <span aria-hidden="true">&rarr;</span></a>
										</article>
									))
								}
							</div>
						</section>
					))
				}
			</div>
		</div>
	</section>
</SiteLayout>

<style>
	.guide-nav {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin-top: var(--space-8);
	}

	.guide-nav-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.75rem 0.95rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-background);
		color: var(--color-primary);
		font-size: 0.9375rem;
		font-weight: 500;
		text-decoration: none;
	}

	.guide-nav-link span {
		color: var(--color-accent);
		font-size: 0.8125rem;
		font-weight: 700;
	}

	.guide-nav-link:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	.guide-clusters {
		display: flex;
		flex-direction: column;
		gap: var(--space-12);
	}

	.priority-lede {
		max-width: 52rem;
	}

	.priority-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-5);
		margin-top: var(--space-8);
	}

	.priority-card {
		display: flex;
		flex-direction: column;
		padding: var(--space-6);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-background);
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.03);
	}

	.priority-card-meta {
		margin: 0 0 var(--space-2);
		color: var(--color-tertiary);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.priority-card h3 {
		margin-bottom: var(--space-3);
		font-size: 1.05rem;
	}

	.priority-card p:not(.priority-card-meta) {
		color: var(--color-secondary);
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.platform-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--space-4);
		margin-top: var(--space-8);
	}

	.platform-card {
		display: flex;
		flex-direction: column;
		padding: var(--space-5);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-background);
	}

	.platform-card h3 {
		margin-bottom: var(--space-3);
		font-size: 1rem;
	}

	.platform-card p:not(.priority-card-meta) {
		color: var(--color-secondary);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.guide-cluster {
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
	}

	.guide-cluster-head {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
		gap: var(--space-6);
		align-items: end;
	}

	.guide-cluster-kicker {
		margin: 0 0 var(--space-2);
		color: var(--color-tertiary);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.guide-cluster-head h2 {
		margin: 0;
	}

	.guide-cluster-count {
		color: var(--color-tertiary);
		font-size: 0.85em;
		font-weight: 600;
	}

	.guide-cluster-description {
