---
import SiteLayout from '../layouts/SiteLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import { getCollection } from 'astro:content';
import { getSubtitleCatalog } from '../lib/subtitles/catalog';
import { guideCategoryMeta, guideCategoryOrder } from '../lib/guides/catalog';
import { SITE_DESCRIPTION, SITE_DOMAIN, SITE_TITLE } from '../consts';

const pageTitle = 'Free Subtitle Tools - No Upload';

const catalog = getSubtitleCatalog('en');
const guides = await getCollection('guides');

const priorityToolIds = [
	'srt-to-vtt',
	'vtt-to-srt',
	'ass-to-srt',
	'subtitle-delay-fixer',
	'subtitle-cleaner',
	'extract-subtitles-from-video',
];

const priorityGuideIds = [
	'how-to-convert-srt-to-vtt-for-html5-video',
	'why-youtube-subtitles-upload-failed',
	'how-to-convert-subtitles-for-youtube',
	'how-to-fix-subtitle-delay',
	'why-srt-file-wont-upload',
	'why-subtitles-do-not-show-in-html5-video',
];

const featuredTools = priorityToolIds
	.map((id) => catalog.tools.find((tool) => tool.id === id))
	.filter(Boolean);
const featuredGuides = priorityGuideIds
	.map((id) => guides.find((guide) => guide.id === id))
	.filter(Boolean);
const guideClusters = guideCategoryOrder
	.map((category) => ({
		category,
		meta: guideCategoryMeta[category],
		count: guides.filter((guide) => guide.data.category === category).length,
		sample: guides.find((guide) => guide.data.category === category),
	}))
	.filter((cluster) => cluster.count > 0);
const popularSearches = [
	{ href: '/guides/how-to-convert-srt-to-vtt-for-html5-video/', label: 'How to convert SRT to VTT for HTML5 video' },
	{ href: '/guides/why-youtube-subtitles-upload-failed/', label: 'Why YouTube subtitles upload failed' },
	{ href: '/guides/how-to-convert-subtitles-for-youtube/', label: 'How to convert subtitles for YouTube' },
	{ href: '/guides/why-videojs-captions-are-not-showing/', label: 'Why Video.js captions are not showing' },
	{ href: '/guides/why-jw-player-captions-are-not-showing/', label: 'Why JW Player captions are not showing' },
	{ href: '/guides/why-plex-subtitles-are-not-showing/', label: 'Why Plex subtitles are not showing' },
	{ href: '/guides/why-vimeo-captions-are-not-showing/', label: 'Why Vimeo captions are not showing' },
	{ href: '/guides/how-to-fix-garbled-subtitles/', label: 'How to fix garbled subtitles' },
	{ href: '/guides/how-to-convert-subtitles-to-utf-8/', label: 'How to convert subtitles to UTF-8' },
	{ href: '/guides/how-to-fix-subtitle-delay/', label: 'How to fix subtitle delay' },
	{ href: '/guides/why-srt-file-wont-upload/', label: "Why SRT file won't upload" },
	{ href: '/guides/best-subtitle-format-for-youtube/', label: 'Best subtitle format for YouTube' },
];

const faqs = [
	{ q: 'Is this really free?', a: 'Yes. All tools are completely free with no limits, no signup, and no hidden paywall.' },
	{ q: 'Are my files uploaded anywhere?', a: 'No. All processing happens locally in your browser. Your files never leave your device.' },
	{ q: 'What subtitle formats are supported?', a: 'SRT, VTT (WebVTT), and ASS. You can convert between any of these formats, shift timing, and clean up formatting.' },
	{ q: 'Do I need to create an account?', a: 'No. There is no login, no account, and no email required. Just open a tool and start using it.' },
	{ q: 'Can I convert SRT to VTT for HTML5 video?', a: 'Yes. Use the SRT to VTT converter to change comma-based timestamps to dots and add the WEBVTT header required for HTML5 video players.' },
	{ q: 'How do I fix subtitle timing issues?', a: 'Use the Subtitle Time Shifter to adjust all timestamps by a fixed amount, or the Partial Subtitle Shifter to fix only a specific time range after a scene cut.' },
	{ q: 'What\'s the best subtitle format for YouTube?', a: 'YouTube accepts both SRT and VTT, but SRT is more reliable. Make sure to use UTF-8 encoding and comma-based timestamps for SRT files.' },
	{ q: 'Can I use these tools on mobile?', a: 'Yes. All tools work in mobile browsers (Safari, Chrome, Firefox). Processing happens in your browser, so no app installation is needed.' },
	{ q: 'Do these tools work offline?', a: 'Once you load a tool page, it works offline. The processing code runs entirely in your browser without needing an internet connection.' },
	{ q: 'How do I clean up subtitle formatting before upload?', a: 'Use the Clean SRT File tool to remove extra blank lines, renumber cues sequentially, and fix common formatting issues that cause upload failures.' },
];

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map(faq => ({
		"@type": "Question",
		"name": faq.q,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.a
		}
	}))
};
---

<SiteLayout title={`${pageTitle} | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
		<JsonLd type="website" data={{
			'@type': 'WebSite',
			name: SITE_TITLE,
			description: SITE_DESCRIPTION,
			url: `https://${SITE_DOMAIN}/`,
		}} />
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
	<!-- Hero -->
	<div class="hero-wrapper">
		<section class="section hero">
		<span class="eyebrow">Free subtitle tools</span>
		<h1>Convert, fix, and clean<br />subtitle files in your browser.</h1>
		<p class="lede">
			Subtitle Toolkit gives you fast, free tools for SRT, VTT, and ASS conversion,
			timing fixes, and format cleanup. No signup, no server upload — everything runs locally.
		</p>
		<div class="button-row">
			<a class="button" href="/tools/">Browse tools <span aria-hidden="true">&rarr;</span></a>
			<a class="button secondary" href="/guides/">Read guides</a>
		</div>
		<ul class="inline-list hero-badges">
			<li>Free forever</li>
			<li>No signup</li>
			<li>Browser-local processing</li>
		</ul>
	</section>
	</div>

	<!-- Popular Searches -->
	<section class="section">
		<span class="eyebrow">Popular searches</span>
		<h2>Jump into the subtitle jobs people search for most.</h2>
		<div class="popular-searches">
			{
				popularSearches.map((item) => (
					<a class="search-chip" href={item.href}>{item.label}</a>
				))
			}
		</div>
	</section>

	<!-- Core Tools -->
	<section class="section-muted">
		<div class="section-inner">
			<span class="eyebrow">Core tools</span>
			<h2>Start with the jobs people actually search for.</h2>
			<p class="lede">{catalog.toolsPage.description}</p>
			<div class="card-grid" style="margin-top: var(--space-8);">
				{
					featuredTools.map((tool) => (
						<article class="card">
							<div class="badge-row">
								<span class="format-badge">{tool.shortTitle}</span>
							</div>
							<h3><a href={`/tools/${tool.id}/`}>{tool.title}</a></h3>
							<p class="muted">{tool.description}</p>
							<a class="card-link" href={`/tools/${tool.id}/`}>Open tool <span aria-hidden="true">&rarr;</span></a>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<!-- Why Section -->
	<section class="section">
		<span class="eyebrow">Why Subtitle Toolkit</span>
		<h2>Built for trust and speed.</h2>
		<div class="trust-grid">
			<div class="trust-item">
				<div class="trust-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
				</div>
				<h3>No server upload</h3>
				<p>Files never leave your browser. All processing happens locally, so privacy is built in by default.</p>
			</div>
			<div class="trust-item">
				<div class="trust-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
				</div>
				<h3>Instant processing</h3>
				<p>No waiting, no queueing. Paste or upload a file and get results immediately.</p>
			</div>
			<div class="trust-item">
				<div class="trust-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
				</div>
				<h3>Free forever</h3>
				<p>No signup, no limits, no paywall. Every tool is completely free to use, now and always.</p>
			</div>
		</div>

		<!-- Ad slot placeholder -->
		<div class="ad-slot" data-ad-slot="home-below-trust" aria-hidden="true"></div>
	</section>

	<!-- Popular Guides -->
	<section class="section-muted">
		<div class="section-inner">
			<span class="eyebrow">Popular guides</span>
			<h2>Learn what format to use and when.</h2>
			<div class="card-grid" style="margin-top: var(--space-8);">
				{
					featuredGuides.map((guide) => (
						<article class="card">
							<h3><a href={`/guides/${guide.id}/`}>{guide.data.title}</a></h3>
							<p class="muted">{guide.data.description}</p>
							<a class="card-link" href={`/guides/${guide.id}/`}>Read guide <span aria-hidden="true">&rarr;</span></a>
						</article>
					))
				}
			</div>
			<div style="margin-top: var(--space-8);">
				<a class="button secondary" href="/guides/">View all guides <span aria-hidden="true">&rarr;</span></a>
			</div>
		</div>
	</section>

	<!-- Guide Clusters -->
	<section class="section">
		<span class="eyebrow">Browse by topic</span>
		<h2>Pick the cluster that matches the job.</h2>
		<p class="lede" style="max-width: 48rem;">
			Every guide on this site is grouped into one of four clusters. Open a cluster to see all its guides and jump straight into the related tool.
		</p>
		<div class="cluster-grid">
			{
				guideClusters.map((cluster) => (
					<a class="cluster-card" href={cluster.meta.hubPath}>
						<p class="cluster-card-count">{cluster.count} guides</p>
						<h3>{cluster.meta.label}</h3>
						<p>{cluster.meta.description}</p>
						{
							cluster.sample && (
								<p class="cluster-card-sample">
									Start with <span class="cluster-card-sample-title">{cluster.sample.data.title}</span>
								</p>
							)
						}
						<span class="card-link">Open cluster <span aria-hidden="true">&rarr;</span></span>
					</a>
				))
			}
		</div>
	</section>

	<!-- FAQ -->
	<section class="section">
		<span class="eyebrow">FAQ</span>
		<h2>Common questions</h2>
		<div class="faq-list">
			{
				faqs.map((faq) => (
					<details class="faq-item">
						<summary class="faq-question">
							{faq.q}
							<span class="faq-icon">+</span>
						</summary>
						<div class="faq-answer">
							<p>{faq.a}</p>
						</div>
					</details>
				))
			}
		</div>
	</section>
</SiteLayout>

<style>
	.hero {
		padding-top: var(--space-20);
		padding-bottom: var(--space-16);
	}

	.hero h1 {
		margin-bottom: var(--space-5);
	}

	.hero-badges {
		margin-top: var(--space-8);
	}

	/* Format arrow */
	.format-arrow {
		color: var(--color-tertiary);
		font-size: 0.75rem;
		font-weight: 600;
	}

	/* Trust grid */
	.trust-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: var(--space-10);
		margin-top: var(--space-10);
	}

	.trust-item {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.trust-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 48px;
		height: 48px;
		border-radius: var(--radius-md);
		background: var(--color-accent-light);
		color: var(--color-accent);
	}

	.trust-item h3 {
		font-size: 1.0625rem;
		margin-bottom: 0;
	}

	.trust-item p {
		color: var(--color-secondary);
		font-size: 0.9375rem;
		margin: 0;
		line-height: 1.6;
	}

	/* FAQ list */
	.faq-list {
		max-width: 48rem;
		margin-top: var(--space-8);
	}

	.cluster-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: var(--space-5);
		margin-top: var(--space-8);
	}

	.cluster-card {
		display: flex;
		flex-direction: column;
		padding: var(--space-6);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(246, 248, 251, 0.9));
		color: var(--color-primary);
		text-decoration: none;
		transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
	}

	.cluster-card:hover {
		border-color: var(--color-accent);
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
	}

	.cluster-card h3 {
		margin-bottom: var(--space-2);
	}

	.cluster-card p {
		margin-bottom: var(--space-3);
		color: var(--color-secondary);
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.cluster-card-count {
		margin: 0 0 var(--space-2);
		color: var(--color-accent);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.cluster-card-sample {
		margin-top: auto;
		color: var(--color-secondary);
		font-size: 0.875rem;
	}

	.cluster-card-sample-title {
		color: var(--color-primary);
		font-weight: 500;
	}

	.cluster-card .card-link {
		margin-top: var(--space-3);
		color: var(--color-accent);
		font-size: 0.875rem;
		font-weight: 600;
	}

	.cluster-card:hover .card-link {
		color: var(--color-accent-hover);
	}

	.popular-searches {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin-top: var(--space-8);
	}

	.search-chip {
		display: inline-flex;
		align-items: center;
		padding: 0.85rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-background);
		color: var(--color-primary);
		font-size: 0.9375rem;
		font-weight: 500;
		line-height: 1.4;
		text-decoration: none;
		transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
	}

	.search-chip:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
		transform: translateY(-1px);
	}

	@media (max-width: 768px) {
		.hero {
			padding-top: var(--space-12);
		}

		.trust-grid {
			gap: var(--space-6);
		}
	}
</style>

<style>
	.hero-wrapper {
		position: relative;
		overflow: hidden;
		background: radial-gradient(circle at 50% 0%, var(--color-accent-light) 0%, transparent 70%);
	}
	.hero-wrapper::before {
		content: '';
		position: absolute;
		top: 0; left: 0; right: 0; height: 1px;
		background: linear-gradient(90deg, transparent, var(--color-accent-muted), transparent);
		opacity: 0.5;
	}
</style>
