---
import SiteLayout from '../layouts/SiteLayout.astro';

const title = 'Page not found';
const description =
	'The page you requested does not exist. Browse the subtitle tools library or return to the homepage.';
---

<SiteLayout title={title} description={description}>
	<section class="not-found">
		<span class="eyebrow">404</span>
		<h1>That page does not exist.</h1>
		<p class="lede">
			The URL may be outdated, removed, or typed incorrectly. The main tool and guide sections are still
			available below.
		</p>
		<div class="button-row">
			<a class="button" href="/tools">Browse tools <span aria-hidden="true">&rarr;</span></a>
			<a class="button secondary" href="/guides">Read guides</a>
			<a class="button secondary" href="/">Back home</a>
		</div>
	</section>
</SiteLayout>

<style>
	.not-found {
		padding: var(--space-16) 0 var(--space-8);
	}
</style>
